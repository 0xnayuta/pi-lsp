{
  "name": "lsp-pi",
  "version": "1.0.1",
  "packageManager": "pnpm@10.33.0",
  "description": "LSP extension for pi-coding-agent - provides language server tool and diagnostics feedback for Dart/Flutter, TypeScript, Vue, Svelte, Python, Go, Kotlin, Swift, Rust, C/C++",
  "scripts": {
    "test": "tsx tests/lsp.test.ts",
    "test:tool": "tsx tests/index.test.ts",
    "test:integration": "tsx tests/lsp-integration.test.ts",
    "test:all": "pnpm test && pnpm test:tool && pnpm test:integration"
  },
  "keywords": [
    "lsp",
    "language-server",
    "dart",
    "flutter",
    "typescript",
    "vue",
    "svelte",
    "python",
    "go",
    "kotlin",
    "swift",
    "rust",
    "clangd",
    "c",
    "cpp",
    "c++",
    "pi-coding-agent",
    "extension",
    "pi-package"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "files": [
    "lsp.ts",
    "lsp-tool.ts",
    "lsp-core.ts",
    "README.md",
    "README.zh.md",
    "LICENSE.txt",
    "package.json"
  ],
  "pi": {
    "extensions": [
      "./lsp.ts",
      "./lsp-tool.ts"
    ]
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.33",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "^0.50.0",
    "@mariozechner/pi-coding-agent": "^0.50.0",
    "@mariozechner/pi-tui": "^0.50.0"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.50.0",
    "@mariozechner/pi-coding-agent": "^0.50.0",
    "@mariozechner/pi-tui": "^0.50.0",
    "@types/node": "^24.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}