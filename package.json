{
  "name": "lsp-pi",
  "version": "1.0.1",
  "packageManager": "pnpm@11.0.9",
  "description": "LSP extension for pi-coding-agent - provides language server tool and diagnostics feedback for Dart/Flutter, TypeScript, Vue, Svelte, Python, Go, Kotlin, Swift, Rust, C/C++",
  "scripts": {
    "test": "node --experimental-strip-types tests/lsp.test.ts",
    "test:tool": "node --experimental-strip-types tests/index.test.ts",
    "test:integration": "node --experimental-strip-types tests/lsp-integration.test.ts",
    "test:all": "pnpm test && pnpm test:tool && pnpm test:integration"
  },
  "keywords": [
    "lsp",
    "language-server",
    "dart",
    "flutter",
    "typescript",
    "vue",
    "svelte",
    "python",
    "go",
    "kotlin",
    "swift",
    "rust",
    "clangd",
    "c",
    "cpp",
    "c++",
    "pi-coding-agent",
    "extension",
    "pi-package"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "files": [
    "lsp.ts",
    "lsp-tool.ts",
    "lsp-core.ts",
    "README.md",
    "README.zh.md",
    "LICENSE.txt",
    "package.json"
  ],
  "pi": {
    "extensions": [
      "./lsp.ts",
      "./lsp-tool.ts"
    ]
  },
  "dependencies": {
    "typebox": "^1.1.38",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "typescript": "^6.0.3"
  }
}